# Copy this file to .env and fill in real values for local runs.
# In GitHub Actions, these are instead supplied via repository secrets
# (see .github/workflows/daily.yml) — this file is only for running
# scraper.py on your own machine. scraper.py reads os.environ directly
# (no dotenv loader), so export these into your shell first, e.g.:
#   export $(grep -v '^#' .env | xargs) && python scraper.py

# Apify API token — Apify Console > Settings > Integrations
APIFY_TOKEN=your-apify-token

# Supabase project URL and service/anon key used to write scraped jobs
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key
