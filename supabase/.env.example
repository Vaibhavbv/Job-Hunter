# Local dev secrets for Supabase Edge Functions.
# Copy to supabase/.env and run: supabase functions serve --env-file supabase/.env
#
# SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY are reserved
# names that Supabase auto-injects into every deployed Edge Function — you
# do NOT set those yourself in production. They're only listed here because
# `supabase functions serve` needs them for local emulation.
#
# GEMINI_API_KEY and APIFY_TOKEN are the only secrets you actually push to
# production, via:
#   supabase secrets set GEMINI_API_KEY=... APIFY_TOKEN=...

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini API key — used by parse-resume, rewrite-resume, evaluate-jobs, score-jobs
GEMINI_API_KEY=your-gemini-api-key

# Apify API token — used by fetch-jobs, ingest-webhook, check-credits
APIFY_TOKEN=your-apify-token
